{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode — Vite handles compilation, not tsc */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Strict TypeScript — catches the most bugs.
     * If you want even more, set: "noUnusedLocals": true, "noUnusedParameters": true
     * (We leave them off for now to avoid false positives on WIP code.) */
    "strict": true,

    /* The path alias — works alongside vite.config.ts.
     * `paths` tells TypeScript: when you see "@/..." in an import,
     * resolve it to "src/..." */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}